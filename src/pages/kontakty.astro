---
import BaseLayout from '../layouts/BaseLayout.astro';
import YandexMap from '../components/YandexMap.astro';
import { contacts } from '../data/contacts';
---

<BaseLayout title="Контакты — автоэлектрик BMW" description="Свяжитесь с автоэлектриком BMW в Санкт-Петербурге. Телефон, Telegram. Адрес мастерской.">
  <section class="contact-page">
    <h1>Контакты</h1>

    <div class="contact-grid">
      <div class="contact-info">
        <h2>Телефон</h2>
        <a href={contacts.phoneHref} class="contact-phone">{contacts.phone}</a>

        <h2>Мессенджеры</h2>
        <div class="messenger-links">
          <a href={contacts.telegram} target="_blank" rel="noopener noreferrer" class="messenger-link messenger-link--tg">Telegram</a>
        </div>

        <h2>Адрес</h2>
        <address>
          <p>Санкт-Петербург</p>
          <p>м. Академическая</p>
        </address>

        <h2>Режим работы</h2>
        <p>Пн–Сб: 10:00–20:00</p>
        <p>Вс: выходной</p>
      </div>

      <YandexMap lat={contacts.coordinates.lat} lng={contacts.coordinates.lng} />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  .contact-page h1 {
    margin-bottom: var(--space-xl);
  }

  .contact-grid {
    display: grid;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-info h2 {
    font-size: var(--font-size-lg);
    margin-top: var(--space-lg);
  }

  .contact-info h2:first-child {
    margin-top: 0;
  }

  .contact-phone {
    font-size: var(--font-size-xl);
    font-weight: 700;
    text-decoration: none;
  }

  .messenger-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .messenger-link {
    display: inline-block;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    font-size: var(--font-size-sm);
  }

  .messenger-link--tg {
    background-color: #0088cc;
  }

  .messenger-link--tg:hover {
    background-color: #006da3;
    color: #fff;
  }

  address {
    font-style: normal;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .contact-info > p {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

</style>
