---
interface Props {
  lat: number;
  lng: number;
  zoom?: number;
  height?: string;
}

const { lat, lng, zoom = 15, height = '400px' } = Astro.props;
const src = `https://yandex.ru/map-widget/v1/?ll=${lng},${lat}&z=${zoom}&pt=${lng},${lat},pm2rdm`;
---

<div class="map-wrap" id="map">
  <iframe
    src={src}
    width="100%"
    height={height}
    frameborder="0"
    allowfullscreen
    loading="lazy"
    title="Расположение мастерской на карте"
  ></iframe>
</div>

<style>
  .map-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .map-wrap iframe {
    display: block;
  }
</style>
