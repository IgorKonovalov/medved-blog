---
import Logo from './Logo.astro';
import { contacts } from '../data/contacts';

const navLinks = [
  { href: '/', label: 'Главная' },
  { href: '/uslugi/', label: 'Услуги' },
  { href: '/blog/', label: 'Блог' },
  { href: '/otzyvy/', label: 'Отзывы' },
  { href: '/o-nas/', label: 'О нас' },
  { href: '/kontakty/', label: 'Контакты' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="header">
  <div class="header-inner">
    <Logo />

    <!-- Phone pill (always visible) -->
    <a href={contacts.phoneHref} class="phone-pill" aria-label={`Позвонить: ${contacts.phone}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span class="phone-text">{contacts.phone}</span>
    </a>

    <!-- Messenger link (desktop only) -->
    <div class="messenger-links">
      <a href={contacts.telegram} target="_blank" rel="noopener noreferrer" aria-label="Написать в Telegram" title="Telegram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
    </div>

    <!-- CSS-only hamburger toggle -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle sr-only" aria-hidden="true" />
    <label for="nav-toggle" class="hamburger" aria-label="Открыть меню">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>

    <!-- Navigation -->
    <nav class="nav" aria-label="Основная навигация">
      <ul class="nav-list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a href={href} class:list={[{ active: isActive(href) }]}>{label}</a>
          </li>
        ))}
      </ul>
      <!-- Mobile-only: messenger in nav drawer -->
      <div class="nav-messengers">
        <a href={contacts.telegram} target="_blank" rel="noopener noreferrer" class="nav-messenger nav-messenger--tg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Telegram
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  /* Phone pill */
  .phone-pill {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-left: auto;
    padding: 0.5rem 1rem;
    background-color: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: var(--font-size-sm);
    text-decoration: none;
    border-radius: 100px;
    white-space: nowrap;
    transition: background-color 0.15s;
  }

  .phone-pill:hover {
    background-color: #b91c1c;
    color: #fff;
  }

  .phone-text {
    display: none;
  }

  @media (min-width: 768px) {
    .phone-text {
      display: inline;
    }
  }

  /* Messenger links (desktop) */
  .messenger-links {
    display: none;
    gap: 0.375rem;
  }

  @media (min-width: 768px) {
    .messenger-links {
      display: flex;
    }
  }

  .messenger-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s;
  }

  .messenger-links a:hover {
    background-color: var(--color-bg-alt);
    color: var(--color-primary);
  }

  /* Hamburger (mobile only) */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0.625rem;
    cursor: pointer;
    border-radius: var(--radius);
    transition: background-color 0.15s;
    flex-shrink: 0;
  }

  .hamburger:hover {
    background-color: var(--color-bg-alt);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (min-width: 768px) {
    .hamburger {
      display: none;
    }
  }

  /* Nav drawer (mobile: hidden by default, desktop: always visible) */
  .nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    padding: var(--space-md);
  }

  .nav-toggle:checked ~ .nav {
    display: block;
  }

  /* Hamburger animation when open */
  .nav-toggle:checked ~ .hamburger .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle:checked ~ .hamburger .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle:checked ~ .hamburger .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nav-list a {
    display: block;
    padding: 0.75rem var(--space-sm);
    font-size: var(--font-size-base);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    border-radius: var(--radius);
    transition: background-color 0.15s, color 0.15s;
  }

  .nav-list a:hover {
    background-color: var(--color-bg-alt);
    color: var(--color-primary);
  }

  .nav-list a.active {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Mobile nav messengers */
  .nav-messengers {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .nav-messenger {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.625rem var(--space-md);
    border-radius: var(--radius);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    color: #fff;
  }

  .nav-messenger--tg { background-color: #0088cc; }
  .nav-messenger--tg:hover { background-color: #006da3; color: #fff; }

  /* Desktop nav */
  @media (min-width: 768px) {
    .nav {
      display: flex;
      position: static;
      background: none;
      border: none;
      box-shadow: none;
      padding: 0;
      order: 2;
      margin-right: auto;
    }

    .nav-list {
      flex-direction: row;
      gap: 0;
    }

    .nav-list a {
      padding: 0.375rem 0.75rem;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
    }

    .nav-list a.active {
      color: var(--color-primary);
    }

    .phone-pill {
      order: 3;
      margin-left: 0;
    }

    .messenger-links {
      order: 4;
    }

    .nav-messengers {
      display: none;
    }
  }
</style>
